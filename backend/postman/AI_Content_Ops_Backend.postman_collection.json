{
  "info": {
    "name": "AI Content Ops Backend (Latest)",
    "_postman_id": "532fa8df-0f7b-47f8-8860-4cfd6ab00f2d",
    "description": "Latest collection aligned with Auth/RBAC, idempotency, thumbnail upload response, workflow gates, media mix stage (MEDIA_MIX_READY), audio generation, and DLQ ops.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.access_token) { pm.collectionVariables.set('access_token', json.data.access_token); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Live",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/api/v1/health/live"
          }
        },
        {
          "name": "Ready",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/api/v1/health/ready"
          }
        },
        {
          "name": "Metrics",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/api/v1/health/metrics"
          }
        }
      ]
    },
    {
      "name": "Videos",
      "item": [
        {
          "name": "Upload File (Multipart)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "uploader_ref",
                  "value": "{{uploader_ref}}",
                  "type": "text"
                },
                {
                  "key": "idempotency_key",
                  "value": "{{idempotency_key}}",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{video_file_path}}"
                }
              ]
            },
            "url": "{{base_url}}/api/v1/videos/upload/file"
          }
        },
        {
          "name": "Upload Complete (Metadata)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uploader_ref\": \"{{uploader_ref}}\",\n  \"filename\": \"demo.mp4\",\n  \"content_type\": \"video/mp4\",\n  \"storage_uri\": \"C:/path/to/video.mp4\",\n  \"idempotency_key\": \"{{idempotency_key}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/videos/upload/complete"
          }
        },
        {
          "name": "Get Video",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/videos/{{video_id}}"
          }
        },
        {
          "name": "Get Video Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/videos/{{video_id}}/status"
          }
        },
        {
          "name": "Get Video Thumbnail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/videos/{{video_id}}/thumbnail"
          }
        },
        {
          "name": "Stream Video",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/videos/{{video_id}}/stream"
          }
        }
      ]
    },
    {
      "name": "Workflow",
      "item": [
        {
          "name": "Run Phase A (Sync)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/workflow/{{job_id}}/phase-a"
          }
        },
        {
          "name": "Run Phase A (Async)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/workflow/{{job_id}}/phase-a/async"
          }
        },
        {
          "name": "Escalate HOLD to Gate 1",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/workflow/{{job_id}}/hold/escalate"
          }
        },
        {
          "name": "Create Gate 1 (Sync)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/workflow/{{job_id}}/gate-1/create"
          }
        },
        {
          "name": "Create Gate 2 (Sync)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/workflow/{{job_id}}/gate-2/create"
          }
        },
        {
          "name": "Finalize (Async)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/workflow/{{job_id}}/finalize/async"
          }
        },
        {
          "name": "Get Async Task Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/workflow/tasks/{{async_task_id}}/status"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "List Tasks (Any Pending)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/reviews/tasks?status=PENDING"
          }
        },
        {
          "name": "List Tasks (Gate 1 Pending)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/reviews/tasks?gate=GATE_1&status=PENDING"
          }
        },
        {
          "name": "List Tasks (Gate 2 Pending)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/reviews/tasks?gate=GATE_2&status=PENDING"
          }
        },
        {
          "name": "Submit Decision (Async progression)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer_ref\": \"{{reviewer_ref}}\",\n  \"decision\": \"APPROVE\",\n  \"notes\": \"approved\"\n}"
            },
            "url": "{{base_url}}/api/v1/reviews/tasks/{{task_id}}/decision?auto_progress=true&async_mode=true"
          }
        },
        {
          "name": "Claim Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/reviews/tasks/{{task_id}}/claim?reviewer_ref={{reviewer_ref}}"
          }
        },
        {
          "name": "Release Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/reviews/tasks/{{task_id}}/release"
          }
        },
        {
          "name": "Escalate Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/reviews/tasks/{{task_id}}/escalate?to_priority=P0&escalated_by=lead_1&reason=urgent"
          }
        },
        {
          "name": "Reopen Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/reviews/tasks/{{task_id}}/reopen?reviewer_ref={{reviewer_ref}}&notes=recheck"
          }
        },
        {
          "name": "SLA Breaches",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/reviews/sla/breaches"
          }
        }
      ]
    },
    {
      "name": "AI / Reports / Wallet / Audit",
      "item": [
        {
          "name": "Get AI Result (Moderator/Admin)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/ai-results/video/{{video_id}}"
          }
        },
        {
          "name": "Get Report",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/reports/video/{{video_id}}"
          }
        },
        {
          "name": "Get Wallet",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/wallet/{{uploader_ref}}"
          }
        },
        {
          "name": "Job Audit",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/audit/job/{{job_id}}"
          }
        },
        {
          "name": "Review Task Audit",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/audit/review_task/{{task_id}}"
          }
        }
      ]
    },
    {
      "name": "Policies",
      "item": [
        {
          "name": "Get Active Policy",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/policies/active"
          }
        },
        {
          "name": "Activate Policy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version\": \"v-next\",\n  \"threshold_p0\": 0.95,\n  \"threshold_p1\": 0.90,\n  \"threshold_p2\": 0.80,\n  \"hold_auto_create_gate1\": true\n}"
            },
            "url": "{{base_url}}/api/v1/policies/activate"
          }
        }
      ]
    },
    {
      "name": "Distribution",
      "item": [
        {
          "name": "Distribution Status by Video",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/distribution/video/{{video_id}}"
          }
        },
        {
          "name": "YouTube OAuth URL",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/distribution/youtube/oauth/url?account_ref={{youtube_account_ref}}"
          }
        },
        {
          "name": "YouTube Integration Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/distribution/youtube/integration/status?account_ref={{youtube_account_ref}}"
          }
        },
        {
          "name": "YouTube Publish",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/distribution/youtube/publish/{{video_id}}?account_ref={{youtube_account_ref}}"
          }
        },
        {
          "name": "YouTube Status Poll",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/distribution/youtube/status/{{external_id}}?account_ref={{youtube_account_ref}}"
          }
        },
        {
          "name": "YouTube Quota",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/distribution/youtube/quota"
          }
        },
        {
          "name": "YouTube Webhook (Manual Test)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-webhook-secret",
                "value": "{{youtube_webhook_secret}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"video_id\": \"{{video_id}}\",\n  \"event_type\": \"YOUTUBE_CALLBACK_TEST\",\n  \"payload\": {\"status\": \"ok\"}\n}"
            },
            "url": "{{base_url}}/api/v1/distribution/youtube/webhook"
          }
        }
      ]
    },
    {
      "name": "Ops (DLQ)",
      "item": [
        {
          "name": "List DLQ",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/ops/dlq"
          }
        },
        {
          "name": "Replay DLQ Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-idempotency-key",
                "value": "{{idempotency_key}}"
              }
            ],
            "url": "{{base_url}}/api/v1/ops/dlq/{{dlq_event_id}}/replay"
          }
        }
      ]
    },
    {
      "name": "Media & Audio (Moderator/Admin)",
      "item": [
        {
          "name": "Audio Options",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/audio-news/options"
          }
        },
        {
          "name": "Generate Audio News",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"raw_details\": \"Breaking update: traffic signal failure at central junction. Emergency response on site.\",\n  \"language\": \"English\",\n  \"style\": \"professional broadcast reporter\",\n  \"voice\": \"Kore\",\n  \"locale\": \"en-IN\"\n}"
            },
            "url": "{{base_url}}/api/v1/audio-news/generate"
          }
        },
        {
          "name": "List Audio News Files",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/audio-news/list"
          }
        },
        {
          "name": "Download Audio News File",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/audio-news/download?filename={{audio_filename}}"
          }
        },
        {
          "name": "Media Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/media/{{video_id}}/status"
          }
        },
        {
          "name": "Retry Media Mix",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/media/{{video_id}}/mix"
          }
        },
        {
          "name": "Stream Mixed Preview",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/media/{{video_id}}/preview/stream"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "username",
      "value": "admin"
    },
    {
      "key": "password",
      "value": "admin123"
    },
    {
      "key": "uploader_ref",
      "value": "demo_user_1"
    },
    {
      "key": "reviewer_ref",
      "value": "moderator_1"
    },
    {
      "key": "video_file_path",
      "value": "C:/path/to/video.mp4"
    },
    {
      "key": "video_id",
      "value": "vid_replace_me"
    },
    {
      "key": "job_id",
      "value": "job_replace_me"
    },
    {
      "key": "task_id",
      "value": "task_replace_me"
    },
    {
      "key": "async_task_id",
      "value": "celery_task_id_replace_me"
    },
    {
      "key": "dlq_event_id",
      "value": "1"
    },
    {
      "key": "youtube_account_ref",
      "value": "default"
    },
    {
      "key": "external_id",
      "value": "youtube_video_id_replace_me"
    },
    {
      "key": "youtube_webhook_secret",
      "value": ""
    },
    {
      "key": "idempotency_key",
      "value": "idem-demo-001"
    },
    {
      "key": "audio_filename",
      "value": "vid_replace_me.mp3"
    }
  ]
}