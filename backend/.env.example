APP_ENV=dev
DEBUG=true
DATABASE_URL=sqlite:///./backend.db
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# Auth
AUTH_JWT_SECRET=replace_with_strong_secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=120
AUTH_DEFAULT_ADMIN_USERNAME=admin
AUTH_DEFAULT_ADMIN_PASSWORD=admin123
AUTH_DEFAULT_MODERATOR_USERNAME=moderator
AUTH_DEFAULT_MODERATOR_PASSWORD=moderator123
AUTH_DEFAULT_UPLOADER_USERNAME=uploader
AUTH_DEFAULT_UPLOADER_PASSWORD=uploader123

# Queue topology
QUEUE_AI_PROCESSING=q.ai_processing
QUEUE_REVIEW=q.review
QUEUE_REVIEW_P0=q.review_p0
QUEUE_REVIEW_P1=q.review_p1
QUEUE_REVIEW_P2=q.review_p2
QUEUE_HOLD=q.hold
QUEUE_DISTRIBUTION=q.distribution
QUEUE_DISTRIBUTION_YOUTUBE=q.distribution_youtube
QUEUE_DISTRIBUTION_SECONDARY=q.distribution_secondary
QUEUE_REPORT=q.report
QUEUE_REWARD=q.reward
QUEUE_DLQ=q.dlq

# LLM provider
MODEL_PROVIDER=gemini
GOOGLE_API_KEY=replace_with_real_key
MODEL_NAME_DEFAULT=gemini-2.5-flash
MODEL_NAME_IMPACT=gemini-2.5-flash
MODEL_NAME_MODERATION=gemini-2.5-flash
MODEL_NAME_CLASSIFICATION=gemini-2.5-flash
MODEL_NAME_COMPLIANCE=gemini-2.5-flash
MODEL_NAME_CONTENT=gemini-2.5-flash
MODEL_NAME_LOCALIZATION=gemini-2.5-flash
MODEL_NAME_REPORTER=gemini-2.5-flash

# YouTube connector
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/distribution/youtube/oauth/callback
YOUTUBE_STRICT_MODE=false
YOUTUBE_DAILY_QUOTA_LIMIT=100
YOUTUBE_PUBLISH_DEFAULT_VISIBILITY=unlisted
YOUTUBE_WEBHOOK_SECRET=

# Optional encryption for integration tokens (generate with Fernet.generate_key()).
TOKEN_ENCRYPTION_KEY=

# Secondary connector
SECONDARY_CHANNEL_WEBHOOK_URL=
SECONDARY_CHANNEL_API_KEY=
SECONDARY_CHANNEL_TIMEOUT_SECONDS=20
SECONDARY_CHANNEL_RETRY_MAX_ATTEMPTS=3
SECONDARY_CHANNEL_STRICT_MODE=false

# ─────────────────────────────────────────────────────────────
# Agentic RAG — Pattern Detection
# ─────────────────────────────────────────────────────────────
PATTERN_DATABASE_URL=postgresql://pattern_user:pattern_pass@localhost:5433/news_patterns

# Gemini embedding model
GEMINI_EMBEDDING_MODEL=gemini-embedding-exp-03-07
PGVECTOR_DIMENSIONS=768

# LLM models for RAG pipeline (reuse GOOGLE_API_KEY above)
ROUTER_MODEL=gemini-2.0-flash
SYNTHESISER_MODEL=gemini-2.5-flash

# Temporal decay (increase for fast-moving news, decrease for slow issues)
TEMPORAL_DECAY_LAMBDA=0.05

# Search defaults
DEFAULT_DAYS_BACK=90
PERSON_SEARCH_DAYS_BACK=180
DEFAULT_LOCATION_RADIUS_METERS=500
SEMANTIC_SIMILARITY_THRESHOLD=0.72
MAX_CANDIDATES_AFTER_MERGE=50
TOP_K_TO_SYNTHESISER=10

# Thread assignment
THREAD_JOIN_CONFIDENCE_THRESHOLD=0.80
THREAD_LINK_CONFIDENCE_THRESHOLD=0.50

# Scoring weights
SCORE_WEIGHT_SEMANTIC=0.45
SCORE_WEIGHT_ENTITY=0.30
SCORE_WEIGHT_TEMPORAL=0.15
SCORE_PROXIMITY_BONUS=0.10
SCORE_PERSON_BONUS=0.10

# Upload security
UPLOAD_MAX_FILE_SIZE_BYTES=524288000
UPLOAD_ALLOWED_MIME_TYPES=video/mp4,video/quicktime,video/x-msvideo,video/x-matroska
MALWARE_SCAN_URL=
MALWARE_SCAN_API_KEY=
MALWARE_SCAN_TIMEOUT_SECONDS=15
