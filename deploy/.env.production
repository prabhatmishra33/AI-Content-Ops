# ==============================================================
# AI Content Ops — Production Environment Variables
# ==============================================================
# Copy this to .env.production and fill in the <PLACEHOLDER> values.
# This file is loaded by docker-compose for api and worker containers.
# ==============================================================

APP_ENV=production
DEBUG=false
DATABASE_URL=sqlite:///./backend.db
REDIS_URL=redis://redis:6379/0

# ── Auth / RBAC ──
AUTH_JWT_SECRET=<GENERATE: python3 -c "import secrets; print(secrets.token_urlsafe(48))">
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=120
AUTH_DEFAULT_ADMIN_USERNAME=admin
AUTH_DEFAULT_ADMIN_PASSWORD=<STRONG_PASSWORD>
AUTH_DEFAULT_MODERATOR_USERNAME=moderator
AUTH_DEFAULT_MODERATOR_PASSWORD=<STRONG_PASSWORD>
AUTH_DEFAULT_UPLOADER_USERNAME=uploader
AUTH_DEFAULT_UPLOADER_PASSWORD=<STRONG_PASSWORD>

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://35.196.100.221
CORS_ALLOW_CREDENTIALS=true

# ── LLM Provider ──
MODEL_PROVIDER=gemini
GOOGLE_API_KEY=<YOUR_GEMINI_API_KEY>
MODEL_NAME_DEFAULT=gemini-2.5-flash
MODEL_NAME_IMPACT=gemini-2.5-flash
MODEL_NAME_MODERATION=gemini-2.5-flash
MODEL_NAME_CLASSIFICATION=gemini-2.5-flash
MODEL_NAME_COMPLIANCE=gemini-2.5-flash
MODEL_NAME_CONTENT=gemini-2.5-flash
MODEL_NAME_LOCALIZATION=gemini-2.5-flash
MODEL_NAME_REPORTER=gemini-2.5-flash

# ── Queue Topology ──
QUEUE_AI_PROCESSING=q.ai_processing
QUEUE_REVIEW=q.review
QUEUE_REVIEW_P0=q.review_p0
QUEUE_REVIEW_P1=q.review_p1
QUEUE_REVIEW_P2=q.review_p2
QUEUE_HOLD=q.hold
QUEUE_DISTRIBUTION=q.distribution
QUEUE_DISTRIBUTION_YOUTUBE=q.distribution_youtube
QUEUE_DISTRIBUTION_SECONDARY=q.distribution_secondary
QUEUE_REPORT=q.report
QUEUE_REWARD=q.reward
QUEUE_DLQ=q.dlq

# ── Upload Security ──
UPLOAD_MAX_FILE_SIZE_BYTES=524288000
UPLOAD_ALLOWED_MIME_TYPES=video/mp4,video/quicktime,video/x-msvideo,video/x-matroska

# ── YouTube (optional) ──
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://35.196.100.221/api/v1/distribution/youtube/oauth/callback
YOUTUBE_STRICT_MODE=false
YOUTUBE_DAILY_QUOTA_LIMIT=100
YOUTUBE_PUBLISH_DEFAULT_VISIBILITY=unlisted
YOUTUBE_WEBHOOK_SECRET=

# ── Token Encryption (optional — generate with Fernet.generate_key()) ──
TOKEN_ENCRYPTION_KEY=

# ── Secondary Connector (optional) ──
SECONDARY_CHANNEL_WEBHOOK_URL=
SECONDARY_CHANNEL_API_KEY=
SECONDARY_CHANNEL_TIMEOUT_SECONDS=20
SECONDARY_CHANNEL_RETRY_MAX_ATTEMPTS=3
SECONDARY_CHANNEL_STRICT_MODE=false

# ── Malware Scan (optional) ──
MALWARE_SCAN_URL=
MALWARE_SCAN_API_KEY=
MALWARE_SCAN_TIMEOUT_SECONDS=15
